---
import BaseLayout from "../layouts/BaseLayout.astro";
import HeroEditorialGrid from "../components/HeroEditorialGrid.astro";
import FeaturedStories from "../components/FeaturedStories.astro";
import ServicesSection from "../components/ServicesSection.astro";
import {
  featuredArticles,
  stories,
  journalEntries,
  services,
} from "../data/content";

const heroFeatured = featuredArticles[0];
const heroSide = featuredArticles.slice(1, 5);
const heroSlugs = featuredArticles.map((a) => a.slug);
const olderArticles = [...stories, ...journalEntries].filter(
  (a, i, arr) => arr.findIndex((x) => x.slug === a.slug) === i
);
---

<BaseLayout
  title="MindForge — Psychologia, Technologia, Marketing & Ciekawostki"
  description="Blog na pograniczu psychologii, technologii, marketingu i ciekawostek. Odkrywaj nowe perspektywy."
>
  <HeroEditorialGrid featured={heroFeatured} sideStories={heroSide} />

  <div class="max-w-[1400px] mx-auto mt-[40px] px-4 md:px-8"><div class="border-t border-[#d4d4d4]"></div></div>

  <FeaturedStories title="Starsze artykuły" stories={olderArticles} excludeSlugs={heroSlugs} />

  <ServicesSection services={services} />
</BaseLayout>
