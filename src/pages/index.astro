---
import BaseLayout from "../layouts/BaseLayout.astro";
import HeroEditorialGrid from "../components/HeroEditorialGrid.astro";
import FeaturedStories from "../components/FeaturedStories.astro";
import ServicesSection from "../components/ServicesSection.astro";
import { getCollection } from "astro:content";
import { services, CATEGORY_IMAGES, type Article } from "../data/content";
import fs from "fs";
import path from "path";

const allPosts = await getCollection("blog", ({ data }) => !data.draft);
allPosts.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const extractSlug = (id: string) => id.replace(/\\/g, "/").split("/").slice(-2, -1)[0] || id;

const toArticle = (entry: typeof allPosts[number]): Article | null => {
  if (!entry.data?.category) return null;
  const slug = extractSlug(entry.id);
  if (!fs.existsSync(path.join(process.cwd(), "public", "articles", slug, "menu_image.jpg"))) return null;
  return {
    slug,
    category: entry.data.category,
    title: entry.data.title,
    description: entry.data.description || "",
    date: entry.data.date.toISOString().slice(0, 10),
    image: `/articles/${slug}/menu_image.jpg`,
  };
};

const articles = allPosts.map(toArticle).filter(Boolean) as Article[];
const heroFeatured = articles[0];
const heroSide = articles.slice(1, 5);
const heroSlugs = articles.slice(0, 5).map((a) => a.slug);
const olderArticles = articles.slice(5);

if (!heroFeatured) {
  throw new Error("No articles found");
}
---

<BaseLayout
  title="Perspektywy — Psychologia, Technologia, Marketing & Ciekawostki"
  description="Blog na pograniczu psychologii, technologii, marketingu i ciekawostek. Odkrywaj nowe perspektywy."
>
  <HeroEditorialGrid featured={heroFeatured} sideStories={heroSide} />

  <div class="max-w-[1600px] mx-auto mt-[40px] px-4 md:px-8"><div class="border-t border-[#d4d4d4]"></div></div>

  <FeaturedStories title="Starsze artykuły" stories={olderArticles} excludeSlugs={heroSlugs} />

  <ServicesSection services={services} />
</BaseLayout>
