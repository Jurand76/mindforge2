---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import { CATEGORIES, type Category } from "../../content.config";
import { CATEGORY_NAMES, CATEGORY_COLORS, CATEGORY_IMAGES } from "../../data/content";
import fs from "fs";
import path from "path";

export async function getStaticPaths() {
  return CATEGORIES.map((cat) => ({ params: { category: cat } }));
}

const { category } = Astro.params as { category: Category };
const extractSlug = (id: string) => id.replace(/\\/g, "/").split("/").slice(-2, -1)[0] || id;
const allPosts = await getCollection("blog", ({ data }) => !data.draft && data.category === category);
allPosts.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
const posts = allPosts.filter((p) => {
  const pslug = extractSlug(p.id);
  return fs.existsSync(path.join(process.cwd(), "public", "articles", pslug, "menu_image.jpg"));
});

const catColor = CATEGORY_COLORS[category];
---

<BaseLayout title={`${CATEGORY_NAMES[category]} | MindForge`} description={`Wpisy z kategorii ${CATEGORY_NAMES[category]}.`}>
  <div class="max-w-[1600px] mx-auto px-4 md:px-8 pt-12 pb-16" style="background: #f0f0f0;">
    {posts.length === 0 ? (
      <p class="text-muted italic">Brak wpisow w tej kategorii.</p>
    ) : (
      <div class="space-y-6">
        {posts.map((post) => {
          const pslug = extractSlug(post.id);
          const img = `/articles/${pslug}/menu_image.jpg`;
          return (
            <a
              href={`/blog/${pslug}`}
              class="group flex flex-col sm:flex-row gap-5 p-4 border border-border hover:border-[#bbb] transition-colors"
            >
              <div class="flex-shrink-0 w-[150px] h-[150px] overflow-hidden bg-[#f0f0f0]">
                <img
                  src={img}
                  alt={post.data.title}
                  class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
                  loading="lazy"
                  decoding="async"
                />
              </div>
              <div class="flex flex-col justify-center min-w-0">
                <div class="flex items-center gap-2 mb-2">
                  <span
                    class="text-[9px] tracking-[0.1em] uppercase font-semibold text-white px-2 py-0.5"
                    style={`background-color: ${catColor}; border-radius: 2px;`}
                  >
                    {CATEGORY_NAMES[category]}
                  </span>
                  <time class="text-xs text-muted">
                    {post.data.date.toLocaleDateString("pl-PL", { year: "numeric", month: "long", day: "numeric" })}
                  </time>
                </div>
                <h2 class="text-lg md:text-xl font-bold leading-tight mb-2 group-hover:text-accent transition-colors" style="font-family: 'Montserrat', sans-serif;">
                  {post.data.title}
                </h2>
                <p class="text-sm text-muted line-clamp-2 mb-3">{post.data.description}</p>
                {post.data.tags && post.data.tags.length > 0 && (
                  <div class="flex flex-wrap gap-2">
                    {post.data.tags.map((tag: string) => (
                      <span class="text-[10px] tracking-[0.05em] uppercase text-muted border border-[#ddd] px-2 py-0.5">{tag}</span>
                    ))}
                  </div>
                )}
              </div>
            </a>
          );
        })}
      </div>
    )}
  </div>
</BaseLayout>
