---
import type { Article } from "../data/content";
import { CATEGORY_COLORS, CATEGORY_NAMES } from "../data/content";

interface Props {
  title: string;
  stories: Article[];
  excludeSlugs: string[];
}

const { title, stories, excludeSlugs } = Astro.props;
const filtered = stories.filter((s) => !excludeSlugs.includes(s.slug));
---

<section id="older" class="max-w-[1400px] mx-auto pl-5 md:pl-9 pr-4 md:pr-8 pt-6 pb-0">
  <div class="flex items-end justify-between mb-4">
    <h2 class="text-2xl md:text-3xl text-black fade-in tracking-wide uppercase">
      {title}
    </h2>
    <div class="flex gap-2" style="margin-top: 3px;">
      <button class="w-10 h-10 flex items-center justify-center border-2 border-black/20 rounded-md hover:border-black hover:bg-black hover:text-white transition-colors" onclick="document.getElementById('carousel-track').scrollBy({left:-320,behavior:'smooth'})">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"></polyline></svg>
      </button>
      <button class="w-10 h-10 flex items-center justify-center border-2 border-black/20 rounded-md hover:border-black hover:bg-black hover:text-white transition-colors" onclick="document.getElementById('carousel-track').scrollBy({left:320,behavior:'smooth'})">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"></polyline></svg>
      </button>
    </div>
  </div>

    <div id="carousel-track" class="overflow-x-auto pb-2 pt-3 p-1 snap-x snap-mandatory no-scrollbar">
    <div class="flex gap-6">
    {filtered.map((story) => (
      <div class="flex-shrink-0 w-[280px] lg:w-[calc(25%-18px)] snap-start fade-in p-1">
        <a
        href={`/blog/${story.slug}`}
        class="group block relative overflow-hidden"
        style="aspect-ratio: 3/4; box-shadow: 0 0 8px rgba(0,0,0,0.6);"
      >
        <img
          src={story.image}
          alt={story.title}
          class="absolute inset-0 w-full h-full object-cover p-1 transition-transform duration-500 group-hover:scale-105"
          loading="lazy"
          decoding="async"
        />
        <div class="absolute inset-0 bg-gradient-to-t from-black/30 via-black/10 to-transparent flex flex-col justify-end" style="padding: 0;">
          <div class="p-3 flex flex-col justify-start overflow-hidden" style="background: rgba(0,0,0,0.5); height: 6rem;">
            <h3 class="text-white leading-tight text-sm line-clamp-2" style="margin-bottom: 0.4rem;">
            {story.title}
          </h3>
          <p class="text-white/70 text-xs leading-snug line-clamp-2 hidden sm:block">
            {story.description}
          </p>
        </div>
        <span
          class="absolute top-3 left-3 text-[10px] tracking-[0.15em] uppercase font-semibold text-white"
          style={`background-color: ${CATEGORY_COLORS[story.category]}; padding: 0.25rem 0.6rem; border-radius: 2px;`}
        >
          {CATEGORY_NAMES[story.category]}
        </span>
        </div>
      </a>
      </div>
    ))}
    </div>
  </div>
</section>

<style>
  .no-scrollbar::-webkit-scrollbar { display: none; }
  .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
</style>
