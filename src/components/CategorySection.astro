---
import type { CollectionEntry } from "astro:content";
import type { Category } from "../content.config";

interface Props {
  category: Category;
  name: string;
  posts: CollectionEntry<"blog">[];
}

const { category, name, posts } = Astro.props;
---

<section class={`cat-section cat-${category}`}>
  <div class="cat-header">
    <h2 class="cat-title">{name}</h2>
    <a href={`/kategoria/${category}`} class="cat-link">Zobacz wszystkie &rarr;</a>
  </div>

  <div class="cat-grid">
    {posts.slice(0, 4).map((post) => (
      <a href={`/blog/${post.id}`} class="cat-card">
        {post.data.cover && (
          <img
            src={post.data.cover.src}
            alt={post.data.title}
            width={post.data.cover.width}
            height={post.data.cover.height}
          />
        )}
        <div class="cat-card-body">
          <time datetime={post.data.date.toISOString()}>
            {post.data.date.toLocaleDateString("pl-PL", {
              month: "short",
              day: "numeric",
            })}
          </time>
          <h3>{post.data.title}</h3>
          <p>{post.data.description}</p>
        </div>
      </a>
    ))}

    {posts.length === 0 && (
      <p class="cat-empty">Brak wpisów w tej kategorii.</p>
    )}
  </div>
</section>

<style>
.cat-section {
  margin-bottom: 3rem;
}

.cat-header {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  margin-bottom: 1.2rem;
  padding-bottom: 0.5rem;
}

.cat-psychologia .cat-header { border-bottom: 3px solid var(--cat-psychologia); }
.cat-technologia .cat-header { border-bottom: 3px solid var(--cat-technologia); }
.cat-ciekawostki .cat-header { border-bottom: 3px solid var(--cat-ciekawostki); }
.cat-marketing .cat-header { border-bottom: 3px solid var(--cat-marketing); }

.cat-title {
  margin: 0;
  font-size: 1.35rem;
}

.cat-psychologia .cat-title { color: var(--cat-psychologia); }
.cat-technologia .cat-title { color: var(--cat-technologia); }
.cat-ciekawostki .cat-title { color: var(--cat-ciekawostki); }
.cat-marketing .cat-title { color: var(--cat-marketing); }

.cat-link {
  font-size: 0.85rem;
  font-family: var(--font-heading);
  white-space: nowrap;
}

.cat-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
  gap: 1.2rem;
}

.cat-card {
  background: var(--color-card);
  border: 1px solid var(--color-border);
  border-radius: var(--radius);
  overflow: hidden;
  color: inherit;
  text-decoration: none;
  transition: box-shadow 0.15s, transform 0.15s;
}

.cat-card:hover {
  box-shadow: 0 4px 16px rgba(0, 0, 0, 0.08);
  transform: translateY(-2px);
  text-decoration: none;
}

.cat-card img {
  width: 100%;
  height: 160px;
  object-fit: cover;
}

.cat-card-body {
  padding: 1rem 1.1rem 1.2rem;
}

.cat-card-body time {
  font-size: 0.72rem;
  color: var(--color-muted);
}

.cat-card-body h3 {
  font-size: 1.05rem;
  margin: 0.3em 0 0.3em;
}

.cat-card-body p {
  font-size: 0.85rem;
  color: var(--color-muted);
  margin: 0;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.cat-empty {
  color: var(--color-muted);
  font-style: italic;
}
</style>
