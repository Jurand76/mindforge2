---
import type { Article } from "../data/content";
import { CATEGORY_COLORS, CATEGORY_NAMES } from "../data/content";

interface Props {
  featured: Article;
  sideStories: Article[];
}

const { featured, sideStories } = Astro.props;
const catColor = CATEGORY_COLORS[featured.category];
---

<section class="max-w-[1400px] mx-auto px-4 md:px-8 pt-12 pb-0">
  <div class="grid grid-cols-2 md:grid-cols-4 gap-3 auto-rows-fr" style="min-height: 500px;">
    <!-- Large -->
    <div class="col-span-2 row-span-2" style="box-shadow: 0 0 8px rgba(0,0,0,0.8);">
      <a
        href={`/blog/${featured.slug}`}
        class="group relative block overflow-hidden h-full"
      >
        <img
          src={featured.image}
          alt={featured.title}
          class="w-full h-full object-cover p-1 transition-transform duration-500 group-hover:scale-105"
          loading="lazy"
          decoding="async"
        />
        <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-black/20 to-transparent flex flex-col justify-end" style="padding: 1.5rem;">
          <h3 class="text-white leading-tight mt-3 text-2xl md:text-3xl">
            {featured.title}
          </h3>
          <p class="text-white/70 text-sm mt-3 max-w-md hidden md:block" style="margin-bottom: 0;">
            {featured.description}
          </p>
        </div>
        <span
          class="absolute top-3 left-3 text-[10px] tracking-[0.15em] uppercase font-semibold text-white"
          style={`background-color: ${catColor}; padding: 0.25rem 0.6rem; border-radius: 2px;`}
        >
          {CATEGORY_NAMES[featured.category]}
        </span>
      </a>
    </div>

    <!-- 4 small tiles -->
    {sideStories.map((story) => {
      const c = CATEGORY_COLORS[story.category];
      return (
        <div style="box-shadow: 0 0 8px rgba(0,0,0,0.8);">
          <a
            href={`/blog/${story.slug}`}
            class="group relative block overflow-hidden h-full"
          >
            <img
              src={story.image}
              alt={story.title}
              class="w-full h-full object-cover p-1 transition-transform duration-500 group-hover:scale-105"
              loading="lazy"
              decoding="async"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-black/20 to-transparent flex flex-col justify-end" style="padding: 1rem;">
              <h4 class="text-white leading-tight text-sm md:text-base">
                {story.title}
              </h4>
            </div>
            <span
              class="absolute top-3 left-3 text-[9px] tracking-[0.15em] uppercase font-semibold text-white"
              style={`background-color: ${c}; padding: 0.2rem 0.5rem; border-radius: 2px;`}
            >
              {CATEGORY_NAMES[story.category]}
            </span>
          </a>
        </div>
      );
    })}
  </div>
</section>
