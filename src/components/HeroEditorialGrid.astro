---
import type { Article } from "../data/content";
import { CATEGORY_COLORS, CATEGORY_NAMES } from "../data/content";

interface Props {
  featured: Article;
  sideStories: Article[];
}

const { featured, sideStories } = Astro.props;
const catColor = CATEGORY_COLORS[featured.category];
---

<section class="max-w-[1600px] mx-auto px-4 md:px-8 pt-12 pb-0" style="background: #f0f0f0;">
  <div class="grid grid-cols-2 md:grid-cols-4 gap-3 auto-rows-fr" style="min-height: 500px;">
    <!-- Large -->
    <div class="col-span-2 row-span-2 lg:aspect-square">
      <a
        href={`/blog/${featured.slug}`}
        class="group relative block overflow-hidden h-full"
        style="padding: 0;"
      >
        <img
          src={featured.image}
          alt={featured.title}
          class="w-full h-full object-cover transition-transform duration-500 scale-[0.98] group-hover:scale-[0.99]"
          loading="lazy"
          decoding="async"
        />
        <span
          class="absolute text-[10px] tracking-[0.15em] uppercase font-semibold text-white z-10"
          style={`top: 1rem; left: 1rem; background-color: ${catColor}; padding: 0.25rem 0.6rem; border-radius: 2px; text-shadow: 0 1px 2px rgba(0,0,0,1);`}
        >
          {CATEGORY_NAMES[featured.category]}
        </span>
        <div class="absolute inset-0 flex flex-col justify-end z-10" style="padding: 5%;">
          <h3 class="text-white leading-tight text-2xl md:text-3xl font-extrabold" style="text-shadow: -1px -1px 0 #000, 1px -1px 0 #000, -1px 1px 0 #000, 1px 1px 0 #000;">
            {featured.title}
          </h3>
          <p class="text-sm mt-2 hidden md:block" style="text-shadow: -1px -1px 0 #000, 1px -1px 0 #000, -1px 1px 0 #000, 1px 1px 0 #000; color: #d0e8d0;">
          {featured.description}
          </p>
        </div>
        <img src="/images/ramka_2.png" alt="" class="absolute inset-0 w-full h-full pointer-events-none z-20" loading="lazy" />
      </a>
    </div>

    <!-- 4 small tiles -->
    {sideStories.map((story) => {
      const c = CATEGORY_COLORS[story.category];
      return (
        <div class="lg:aspect-square">
          <a
            href={`/blog/${story.slug}`}
            class="group relative block overflow-hidden h-full"
            style="padding: 0;"
          >
            <img
              src={story.image}
              alt={story.title}
          class="w-full h-full object-cover transition-transform duration-500 scale-[0.98] group-hover:scale-[0.99]"
              loading="lazy"
              decoding="async"
            />
            <span
              class="absolute text-[9px] tracking-[0.15em] uppercase font-semibold text-white z-10"
              style={`top: 1rem; left: 1rem; background-color: ${c}; padding: 0.2rem 0.5rem; border-radius: 2px; text-shadow: 0 1px 2px rgba(0,0,0,1);`}
            >
              {CATEGORY_NAMES[story.category]}
            </span>
            <div class="absolute inset-0 flex flex-col justify-end z-10" style="padding: 5%;">
              <h4 class="text-white leading-tight text-base md:text-lg font-extrabold" style="text-shadow: -1px -1px 0 #000, 1px -1px 0 #000, -1px 1px 0 #000, 1px 1px 0 #000;">
                {story.title}
              </h4>
            </div>
            <img src="/images/ramka_2.png" alt="" class="absolute inset-0 w-full h-full pointer-events-none z-20" loading="lazy" />
          </a>
        </div>
      );
    })}
  </div>
</section>
