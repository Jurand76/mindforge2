---
import type { CollectionEntry } from "astro:content";
import type { Category } from "../content.config";

interface Props {
  post: CollectionEntry<"blog">;
}

const { post } = Astro.props;
const { id: slug } = post;
const { title, description, date, category, tags, cover } = post.data;

const CATEGORY_NAMES: Record<Category, string> = {
  psychologia: "Psychologia",
  technologia: "Technologia",
  ciekawostki: "Ciekawostki",
  marketing: "Marketing",
};
---

<article class="post-card">
  <a href={`/blog/${slug}`} class="card-link">
    {cover && (
      <img
        src={cover.src}
        alt={title}
        class="card-cover"
        width={cover.width}
        height={cover.height}
      />
    )}
    <div class="card-body">
      <div class="card-meta">
        <span class={`cat-badge cat-${category}`}>{CATEGORY_NAMES[category]}</span>
        <time datetime={date.toISOString()}>
          {date.toLocaleDateString("pl-PL", {
            year: "numeric",
            month: "long",
            day: "numeric",
          })}
        </time>
      </div>
      <h2>{title}</h2>
      <p>{description}</p>
      {tags.length > 0 && (
        <div class="tags">
          {tags.map((tag) => <span class="tag">#{tag}</span>)}
        </div>
      )}
    </div>
  </a>
</article>

<style>
.post-card {
  background: var(--color-card);
  border: 1px solid var(--color-border);
  border-radius: var(--radius);
  margin-bottom: 1.5rem;
  overflow: hidden;
  transition: box-shadow 0.15s;
}

.post-card:hover {
  box-shadow: 0 2px 12px rgba(0, 0, 0, 0.06);
}

.card-link {
  color: inherit;
  text-decoration: none;
  display: block;
}

.card-cover {
  width: 100%;
  height: 220px;
  object-fit: cover;
}

.card-body {
  padding: 1.2rem 1.5rem 1.5rem;
}

.card-meta {
  display: flex;
  align-items: center;
  gap: 0.6rem;
  margin-bottom: 0.3rem;
}

.card-meta time {
  font-size: 0.8rem;
  color: var(--color-muted);
}

.cat-badge {
  font-family: var(--font-heading);
  font-size: 0.68rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  padding: 0.15em 0.55em;
  border-radius: 999px;
  background: var(--color-code-bg);
}

.cat-psychologia { color: var(--cat-psychologia); }
.cat-technologia { color: var(--cat-technologia); }
.cat-ciekawostki { color: var(--cat-ciekawostki); }
.cat-marketing { color: var(--cat-marketing); }

.card-body h2 {
  margin: 0.25em 0 0.3em;
  font-size: 1.35rem;
}

.card-body p {
  color: var(--color-muted);
  font-size: 0.95rem;
  margin-bottom: 0.6em;
}

.tags {
  display: flex;
  flex-wrap: wrap;
  gap: 0.4rem;
  margin-top: 0.5rem;
}

.tag {
  font-size: 0.75rem;
  font-family: var(--font-mono);
  background: var(--color-code-bg);
  padding: 0.15em 0.55em;
  border-radius: 999px;
  color: var(--color-muted);
}
</style>
