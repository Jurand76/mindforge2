---
import type { Article } from "../data/content";
import { CATEGORY_COLORS, CATEGORY_NAMES } from "../data/content";

interface Props {
  entries: Article[];
}

const { entries } = Astro.props;
---

<section id="journal" class="bg-stone-50 py-16 md:py-24">
  <div class="max-w-[1400px] mx-auto px-4 md:px-8">
    <h2 class="text-2xl md:text-3xl text-black mb-12 fade-in">
      Najnowsze wpisy
    </h2>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      {entries.map((entry) => (
        <a href={`/blog/${entry.slug}`} class="group block fade-in">
          <div class="overflow-hidden mb-5">
            <img
              src={entry.image}
              alt={entry.title}
              class="w-full object-cover transition-transform duration-500 group-hover:scale-105"
              style="aspect-ratio: 3/2"
              loading="lazy"
              decoding="async"
            />
          </div>
          <div class="flex items-center gap-2 mb-1">
            <span
              class="text-[10px] tracking-[0.15em] uppercase font-semibold"
              style={`color: ${CATEGORY_COLORS[entry.category]}`}
            >
              {CATEGORY_NAMES[entry.category]}
            </span>
            <span class="text-[10px] text-muted">&middot;</span>
            <span class="text-xs text-muted">{entry.date}</span>
          </div>
          <h3 class="text-xl mt-1 mb-2 group-hover:text-accent transition-colors">
            {entry.title}
          </h3>
          <p class="text-sm text-muted leading-relaxed">
            {entry.description}
          </p>
          <span class="inline-block mt-4 text-[10px] tracking-[0.2em] uppercase text-black border-b border-black pb-1 group-hover:text-accent group-hover:border-accent transition-colors">
            Czytaj
          </span>
        </a>
      ))}
    </div>
  </div>
</section>
